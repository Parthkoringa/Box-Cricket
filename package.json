{
  "name": "box-cricket",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n api,web \"npm run dev:api\" \"npm --prefix frontend run start\"",
    "dev:api": "tsx watch api/_local-dev.ts",
    "build": "npm --prefix frontend install && npm --prefix frontend run build",
    "test:api": "vitest run",
    "typecheck": "tsc --noEmit",
    "seed:users": "tsx db/seed-users.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.0",
    "bcryptjs": "^2.4.3",
    "express": "^5.0.1",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "@types/supertest": "^6.0.2",
    "concurrently": "^10.0.3",
    "dotenv": "^16.4.7",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
